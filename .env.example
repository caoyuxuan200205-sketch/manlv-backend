## Database
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/manlv_db?schema=public"

## Auth
JWT_SECRET="replace_with_a_strong_jwt_secret"

## Feishu OAuth
## Redirect URI must be added in the Feishu developer console security settings.
FEISHU_CLIENT_ID="cli_xxxxxxxxxxxxxxxx"
FEISHU_CLIENT_SECRET="xxxxxxxxxxxxxxxx"
## Local example:
## FEISHU_REDIRECT_URI="http://localhost:3001/api/auth/feishu/callback"
## Same-domain production example for https://www.manlvai.site :
FEISHU_REDIRECT_URI="https://www.manlvai.site/api/auth/feishu/callback"
FEISHU_OAUTH_SCOPES="auth:user.id:read user_profile offline_access"
FEISHU_OAUTH_PROMPT="consent"
## Optional: redirect users back to H5/App after binding completes.
FEISHU_OAUTH_SUCCESS_REDIRECT="https://www.manlvai.site/oauth/feishu/result"
FEISHU_OAUTH_FAILURE_REDIRECT="https://www.manlvai.site/oauth/feishu/result"
## Optional: comma-separated allowlist for frontend redirect origins.
FEISHU_ALLOWED_REDIRECT_ORIGINS="https://www.manlvai.site"

## Server
PORT="3001"

## AI
AI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
AI_API_KEY="sk-xxxxxxxxxxxxxxxx"
AI_MODEL="qwen-plus"
AI_MAX_STEPS="6"

## Search / Map
AMAP_API_KEY="your_amap_api_key"
TAVILY_API_KEY="tvly-xxxxxxxxxxxxxxxx"
## Tencent News CLI integration
## 1) Install CLI first. Windows: irm https://mat1.gtimg.com/qqcdn/qqnews/cli/hub/tencent-news/setup.ps1 | iex
##    macOS/Linux: curl -fsSL https://mat1.gtimg.com/qqcdn/qqnews/cli/hub/tencent-news/setup.sh | sh
## 2) Visit https://news.qq.com/exchange?scene=appkey to generate your API Key.
TENCENT_NEWS_API_KEY=""
## Optional: override CLI executable path when it is not on PATH.
## On Railway/Linux, leave this empty unless you want to use a custom Linux path.
TENCENT_NEWS_CLI_PATH=""
## Optional: override CLI install root. By default Railway/Linux uses ./.tencent-news-cli.
TENCENT_NEWS_INSTALL=""
## Optional: caller identifier reported to the CLI.
TENCENT_NEWS_CALLER="manlv-backend"
## Optional: CLI timeout in milliseconds.
TENCENT_NEWS_TIMEOUT_MS="15000"
 
## Meituan Travel Skill integration
## 1) Login to https://open.meituan.com/ to get your Token.
## 2) The backend will automatically write the config to ~/.config/meituan-travel/config.json.
MEITUAN_TRAVEL_TOKEN=""

## MCP
## Windows paths inside JSON should use forward slashes or escaped backslashes.
MCP_SERVERS_JSON='[{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","C:/Users/your_name/Desktop/manlv-backend"]}]'

## Optional prompt overrides
AI_SYSTEM_PROMPT="你是漫旅 AI 助手。你的目标是帮助用户完成保研行程管理、冲突分析、面试准备，并在需要时调用可用工具。请先思考，再给出简洁、可执行的建议。"
AI_SYSTEM_PROMPT_ADVISOR=""
AI_SYSTEM_PROMPT_INTERVIEWER=""
