// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password      String
  name          String
  major         String?
  memorySummary String?     @db.Text
  memoryFacts   Json?
  mcpServers    Json?
  mcpEnabled    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  emails        Email[]
  interviews    Interview[]
  tripPlans     TripPlan[]
}

model Email {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    String
  body       String
  sender     String
  receivedAt DateTime
  parsedData Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Interview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school    String
  major     String
  date      DateTime
  city      String
  type      String
  createdAt DateTime @default(now())
}

model TripPlan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  route     String
  cost      String
  duration  String
  fatigue   String
  score     Int
  desc      String
  recommend Boolean  @default(false)
  planData  Json
  createdAt DateTime @default(now())
}
